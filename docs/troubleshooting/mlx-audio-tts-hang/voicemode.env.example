# ----------------------------------------------------------------------------
# VoiceMode hybrid local-voice configuration for Apple Silicon
# TTS: mlx-audio (:8890) with Kokoro (:8880) as fallback
# STT: whisper.cpp (:2022)
#
# Verified on voice-mode 8.10.2 + mlx-audio 0.4.3, MacBook Pro M-series.
# Note: as of VM-1390 VoiceMode resolves the model per endpoint, so mlx-audio
# gets its real repo id automatically — the explicit VOICEMODE_TTS_MODELS below
# is no longer required, just an explicit override. On older builds it IS
# required: a generic name like "tts-1" makes mlx-audio try to fetch a
# nonexistent HuggingFace repo and the request hangs.
# ----------------------------------------------------------------------------

# --- TTS ---
VOICEMODE_MLX_AUDIO_BASE_URL=http://127.0.0.1:8890/v1
VOICEMODE_TTS_BASE_URLS=http://127.0.0.1:8890/v1,http://127.0.0.1:8880/v1

# THE critical line: a real, locally cached MLX model repo id, NOT "tts-1"
VOICEMODE_TTS_MODELS=mlx-community/Kokoro-82M-bf16

# --- STT ---
VOICEMODE_STT_BASE_URLS=http://127.0.0.1:2022/v1
# VOICEMODE_STT_MODEL intentionally unset: whisper.cpp uses its own default
# (see VOICEMODE_WHISPER_MODEL)
VOICEMODE_WHISPER_MODEL=large-v2

# --- Provider preference ---
VOICEMODE_PREFER_LOCAL=true
VOICEMODE_ALWAYS_TRY_LOCAL=true

# --- Optional: voice and rate defaults ---
# VOICEMODE_VOICES=af_bella
# VOICEMODE_TTS_SPEED=1.25

# ----------------------------------------------------------------------------
# Rollback options
#
# Full-legacy (kokoro + whisper.cpp):
#   VOICEMODE_TTS_BASE_URLS=http://127.0.0.1:8880/v1
#   VOICEMODE_STT_BASE_URLS=http://127.0.0.1:2022/v1
#   (unset VOICEMODE_TTS_MODELS)
#
# Full-mlx (TTS + STT both via mlx-audio):
#   VOICEMODE_TTS_BASE_URLS=http://127.0.0.1:8890/v1
#   VOICEMODE_STT_BASE_URLS=http://127.0.0.1:8890/v1
#   VOICEMODE_STT_MODEL=mlx-community/whisper-large-v2-mlx
# ----------------------------------------------------------------------------
